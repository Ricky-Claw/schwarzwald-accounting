{
  "name": "schwarzwald-accounting",
  "version": "1.0.0",
  "description": "Buchhaltungs-Management für Schwarzwald Agent",
  "main": "dist/app.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "test": "vitest --passWithNoTests",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset"
  },
  "keywords": [
    "accounting",
    "buchhaltung",
    "datev",
    "ocr"
  ],
  "author": "Schwarzwald Agent",
  "license": "MIT",
  "dependencies": {
    "@azure/ai-form-recognizer": "^5.0.0",
    "@supabase/supabase-js": "^2.39.0",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.2",
    "date-fns": "^3.0.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "pdf2pic": "^3.2.0",
    "xml2js": "^0.6.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.4",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  }
}
